GOOGLE_API_KEY=your_google_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=clinical-ai-copilot
COPILOT_MODEL=gemini-1.5-pro
COPILOT_ENABLE_PUBMED=1
COPILOT_PUBMED_MAX_RESULTS=5

# Set to 1 to use LangGraph interrupt() as a real human approval pause.
COPILOT_ENABLE_HUMAN_INTERRUPT=0

# Set to 1 for offline demos without an LLM call.
COPILOT_MOCK_LLM=1
